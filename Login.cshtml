@model LoginFormModel
@{
    ViewData["Title"] = "Log in";
}

<div class="befit-register-wrapper">
    <div class="befit-card shadow-lg">
        <div class="befit-card-header text-center">
            <span class="brand-badge mb-2">BeFit</span>
            <h2 class="fw-bold m-0">Welcome Back</h2>
            <p class="text-muted small mb-0 mt-1">Log in to manage your sport events</p>
        </div>

        <div class="befit-card-body">
            <section>
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control custom-input" autocomplete="username" aria-required="true" placeholder="Email" />
                        <label asp-for="Email" class="form-label"></label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Password" class="form-control custom-input" autocomplete="current-password" aria-required="true" placeholder="Password" />
                        <label asp-for="Password" class="form-label"></label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input class="form-check-input" asp-for="RememberMe" id="rememberMeCheck" />
                        <label class="form-check-label text-secondary small" for="rememberMeCheck">
                            @Html.DisplayNameFor(m => m.RememberMe)
                        </label>
                    </div>

                    <div class="mb-3">
                        <button id="login-submit" type="submit" class="btn btn-befit btn-lg w-100">
                            Log in
                        </button>
                    </div>

                    <div class="text-center mt-3">
                        <p class="mb-0 text-muted small">
                            Don't have an account?
                            <a asp-controller="User" asp-action="Register" class="text-primary text-decoration-none fw-bold">Register as a new user</a>
                        </p>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}