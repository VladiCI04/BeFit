@using BeFit.Services.Data.Interfaces
@using BeFit.Web.Infrastructure.Extensions

@inject ICoachService coachService
@{
    ViewData["Title"] = "Home Page";
    List<IndexViewModel> events = Model.ToList();

    bool isUserCoach = await coachService.CoachExistsByUserIdAsync(this.User.GetId()!);
}

@model IEnumerable<IndexViewModel>

@if (!events.Any())
{
    <div class="p-5 my-4 bg-white rounded-4 border shadow-sm text-center">
        <h1 class="display-5 fw-bold text-dark">Welcome to BeFit!</h1>
        <p class="lead text-muted my-3">
            There are no events currently available. Why don't you kick things off and start one?
        </p>
        <hr class="my-4 w-25 mx-auto opacity-25">
        @if (this.User.Identity!.IsAuthenticated)
        {
            if (isUserCoach)
            {
                <a asp-area="" asp-controller="Event" asp-action="Add" class="btn btn-primary btn-lg rounded-pill fw-bold px-4" role="button">
                    <i class="bi bi-plus-circle me-2"></i>Add Event
                </a>
            }
        }
    </div>
}

<div class="text-center my-4 p-4 rounded-4 bg-primary text-white shadow-sm position-relative overflow-hidden">
    @if (this.User.Identity!.IsAuthenticated)
    {
        if (isUserCoach)
        {
            <h4 class="fw-bold mb-1 text-uppercase tracking-wider">Coach Portal</h4>
            <p class="mb-0 opacity-90 fs-6">You are now a coach! Organize your own sports events and inspire your community.</p>
        }
        else
        {
            <h4 class="fw-bold mb-1 text-uppercase tracking-wider">Welcome Back!</h4>
            <p class="mb-0 opacity-90 fs-6">Sign up for upcoming sports events or apply to become a coach!</p>
        }
    }
    else
    {
        <h4 class="fw-bold mb-1 text-uppercase tracking-wider">Welcome to BeFit</h4>
        <p class="mb-0 opacity-90 fs-6">Create an account to participate in sports events or host your own!</p>
    }
</div>

@if (events.Any())
{
    <div id="carouselExampleControls" class="carousel slide rounded-4 overflow-hidden shadow-lg my-4" data-bs-ride="carousel">
        <div class="carousel-inner">
            @for (int i = 0; i < events.Count(); i++)
            {
                IndexViewModel even = events[i];
                <div class="carousel-item @(i == 0 ? "active" : string.Empty)">
                    <div class="position-relative">
                        <img class="d-block w-100 object-fit-cover" style="height: 480px;" src="@even.ImageUrl" alt="@even.Title">
                        <div class="carousel-gradient-overlay position-absolute top-0 start-0 w-100 h-100"></div>
                    </div>
                    <div class="carousel-caption d-block pb-4">
                        <h3 class="fw-bold text-white mb-3 text-shadow">@even.Title</h3>
                        <a class="btn btn-primary btn-lg rounded-pill fw-bold px-4 shadow" asp-area="" asp-controller="Event" asp-action="Details" asp-route-id="@even.Id">
                            View Event Details
                        </a>
                    </div>
                </div>
            }
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
}
