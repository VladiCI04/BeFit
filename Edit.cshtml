@model EventFormModel
@{
    ViewData["Title"] = "Edit Event";
}

<div class="container my-4">
    <div class="text-center mb-4">
        <span class="brand-badge mb-2">Management</span>
        <h2 class="fw-bold text-dark m-0">@ViewData["Title"]</h2>
        <p class="text-muted small mt-1">Update the details and schedule for your sports event</p>
        <hr class="w-25 mx-auto opacity-25 mt-3" />
    </div>

    <partial name="_EventFormPartial" model="@Model" />
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}