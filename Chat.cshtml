@using BeFit.Services.Data.Interfaces
@inject IUserService userService
@{
    string? userFullName = await this.userService.GetFullNameByEmailAsync(this.User.Identity!.Name!);
    ViewData["Title"] = "Community Chat";
}

<div class="befit-register-wrapper my-5" style="max-width: 720px;">
    <div class="befit-card shadow-lg overflow-hidden">

        <div class="befit-card-header text-center py-3 border-bottom">
            <span class="brand-badge mb-1">Live Chat</span>
            <h3 class="fw-bold m-0 text-dark">@ViewData["Title"]</h3>
            <p class="text-muted small mb-0 mt-1">Connect in real-time with other BeFit members and coaches</p>
        </div>

        <div class="befit-card-body p-4 p-md-5">

            <div class="row g-3 mb-4">

                <div class="col-md-5">
                    <label for="userInput" class="form-label fw-semibold text-secondary small mb-1">Your Name</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted border-end-0">
                            <i class="bi bi-person-fill"></i>
                        </span>
                        <input type="text" id="userInput" value="@userFullName" class="form-control bg-light border-start-0" readonly />
                    </div>
                </div>

                <div class="col-md-7">
                    <label for="messageInput" class="form-label fw-semibold text-secondary small mb-1">Your Message</label>
                    <div class="input-group">
                        <input type="text" id="messageInput" class="form-control" placeholder="Type a message..." />
                        <button type="button" id="sendButton" class="btn btn-befit fw-bold px-4">
                            Send <i class="bi bi-send-fill ms-1 small"></i>
                        </button>
                    </div>
                </div>

            </div>

            <hr class="my-4 opacity-25" />

            <div>
                <h6 class="fw-bold text-secondary mb-3">
                    <i class="bi bi-chat-dots-fill text-primary me-2"></i>Messages
                </h6>
                <div class="bg-light border rounded-3 p-3 overflow-auto" style="max-height: 350px; min-height: 200px;">
                    <ul id="messagesList" class="list-unstyled mb-0 d-flex flex-column gap-2">
                    </ul>
                </div>
            </div>

        </div>

    </div>
</div>

<script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
<script src="~/js/chat.js" asp-append-version="true"></script>