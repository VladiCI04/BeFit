@using BeFit.Services.Data.Interfaces
@using BeFit.Web.Infrastructure.Extensions

@inject ICoachService CoachService
@{
    bool isUserCoach = await CoachService.CoachExistsByUserIdAsync(this.User.GetId()!);
    ViewBag.Title = "BeFit";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.4/toastr.min.css" integrity="sha512-6S2HWzVFxruDlZxI3sXOZZ4/eJ8AcxkQH1+JjSe/ONCEqR9L4Ysq5JdT5ipqtzU7WHalNwzwBv+iE51gNHJNqQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BeFit.styles.css" asp-append-version="true" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.4/toastr.min.js" integrity="sha512-lbwH47l/tPXJYG9AcFNoJaTMhGvYWhVM9YI43CT+uteTRRaiLCui8snIgyAN8XWgNjNhCqlAUdzZptso6OCoFQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">
    <partial name="_NotificationsPartial" />

    <header class="sticky-top bg-white border-bottom shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-light py-2">
            <div class="container">
                <a class="navbar-brand me-4 d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/befit-logo.png" alt="BeFit Logo" class="brand-logo" />
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#befitNavbar" aria-controls="befitNavbar"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="befitNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center gap-1">
                        <li class="nav-item">
                            <a class="nav-link fw-semibold px-2 hover-link" asp-area="" asp-controller="Event" asp-action="All">All Events</a>
                        </li>

                        @if (this.User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-semibold px-2 hover-link" asp-area="" asp-controller="Event" asp-action="Mine">My Events</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-semibold px-2 hover-link" asp-area="" asp-controller="Chat" asp-action="Chatting">Online Chat</a>
                            </li>
                            if (isUserCoach)
                            {
                                <li class="nav-item">
                                    <a class="nav-link fw-semibold px-2 hover-link text-primary" asp-area="" asp-controller="Event" asp-action="Add">Create Event</a>
                                </li>
                            }
                        }

                        <li class="nav-item">
                            <a class="nav-link fw-semibold px-2 hover-link" asp-area="" asp-controller="EventCategory" asp-action="All">Event Categories</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold px-2 hover-link" asp-area="" asp-controller="CoachCategory" asp-action="All">Coach Categories</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center mt-3 mt-lg-0">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1 my-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-white border-top py-3 mt-auto text-center text-muted small">
        <div class="container">
            &copy; @DateTime.Now.Year - <span class="fw-bold text-primary">BeFit</span>. All rights reserved.
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>