@model List<EventAllViewModel>
@{
    ViewData["Title"] = "My Events";
}

<div class="container my-4">
    <div class="text-center mb-4">
        <span class="brand-badge mb-2">Dashboard</span>
        <h2 class="fw-bold text-dark m-0">@ViewData["Title"]</h2>
        <p class="text-muted small mt-1">Manage and view all the sports events you are attending or organizing</p>
        <hr class="w-25 mx-auto opacity-25 mt-3" />
    </div>

    @if (!Model.Any())
    {
        <div class="befit-register-wrapper my-5" style="max-width: 580px;">
            <div class="befit-card shadow-lg text-center p-4 p-md-5">
                <div class="mb-3">
                    <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle p-4 shadow-sm" style="width: 80px; height: 80px;">
                        <i class="bi bi-calendar-x-fill fs-2"></i>
                    </div>
                </div>
                <h4 class="fw-bold text-dark mb-2">No Events Found</h4>
                <p class="text-muted mb-4">You have not joined or organized any sports events yet.</p>
                <div>
                    <a asp-area="" asp-controller="Event" asp-action="All" class="btn btn-befit rounded-pill fw-bold px-4 py-2">
                        <i class="bi bi-search me-1"></i> Browse All Events
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (EventAllViewModel even in Model)
            {
                <partial name="_EventPartial" model="even" />
            }
        </div>
    }
</div>