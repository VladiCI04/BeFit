@{
    ViewData["Title"] = "Error";
}

<div class="befit-register-wrapper my-5" style="max-width: 580px;">
    <div class="befit-card shadow-lg text-center overflow-hidden">

        <div class="befit-card-header bg-light py-3 border-bottom">
            <span class="brand-badge bg-danger text-white mb-1">System Error</span>
            <h3 class="fw-bold m-0 text-danger">Error.</h3>
        </div>

        <div class="befit-card-body p-4 p-md-5">
            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 text-danger rounded-circle p-4 shadow-sm" style="width: 90px; height: 90px;">
                    <i class="bi bi-exclamation-triangle-fill fs-1"></i>
                </div>
            </div>

            <h4 class="fw-semibold text-secondary mb-4">
                An error occurred while processing your request.
            </h4>

            <div class="pt-2">
                <a asp-area="" asp-controller="Home" asp-action="Index"
                   class="btn btn-befit btn-lg px-4 rounded-pill fw-bold text-decoration-none d-inline-flex align-items-center gap-2">
                    <i class="bi bi-house-door-fill"></i> Go back to Home Page
                </a>
            </div>
        </div>

    </div>
</div>